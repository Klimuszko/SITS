# ----------------------------------------------------------------------------
# Szablon .env dla wdrożenia produkcyjnego (skopiuj na serwerze do pliku .env).
# Plik .env jest używany jednocześnie przez aplikację (env_file) ORAZ przez
# docker compose do podstawienia zmiennych ${APP_IMAGE} / ${NGINX_IMAGE}.
# ----------------------------------------------------------------------------

# Obrazy z GHCR – podmień "uzytkownik/sits" na swoje repozytorium (małe litery).
APP_IMAGE=ghcr.io/uzytkownik/sits-app:latest
NGINX_IMAGE=ghcr.io/uzytkownik/sits-nginx:latest

APP_NAME="SerwisIT"
APP_ENV=production
# WYGENERUJ: docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
# Ustaw realny adres/IP serwera:
APP_URL=http://ADRES_SERWERA:7564
APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Europe/Warsaw

# Konto Super Admina (używane przy jednorazowym seedzie konta administratora).
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_EMAIL=admin@twojadomena.pl
SUPERADMIN_PASSWORD=ZMIEN_TO_HASLO

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=serwisit
DB_USERNAME=serwisit
DB_PASSWORD=ZMIEN_SILNE_HASLO_BAZY

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

# Skonfiguruj prawdziwy SMTP do powiadomień e-mail.
MAIL_MAILER=log
MAIL_HOST=smtp.twojadomena.pl
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@twojadomena.pl"
MAIL_FROM_NAME="${APP_NAME}"
