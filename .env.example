APP_NAME="SerwisIT"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:7564
APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL
APP_TIMEZONE=Europe/Warsaw

# Konto Super Admina tworzone przez seeder (zmień przed produkcją!)
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_EMAIL=admin@serwisit.local
SUPERADMIN_PASSWORD=Admin12345!

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Baza danych (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=serwisit
DB_USERNAME=serwisit
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Cache / kolejki / sesje przez Redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Pliki / załączniki – dysk prywatny (pobieranie tylko przez kontroler z autoryzacją)
FILESYSTEM_DISK=local

# Poczta (na start log – maile trafiają do storage/logs)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@serwisit.local"
MAIL_FROM_NAME="${APP_NAME}"
